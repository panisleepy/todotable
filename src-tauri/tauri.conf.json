{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibe-diary",
  "version": "0.3.0",
  "identifier": "app.vibe-diary",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "node scripts/build-dist.mjs",
    "beforeBuildCommand": "node scripts/build-dist.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Working Table Diary",
        "width": 440,
        "height": 1000,
        "minWidth": 380,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/binglehaepi/workingtable/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4NDA5NDJERjQ5OUIzQjQKUldTMHM1bjBMWlJBU1BFUVkyRnErc05BTXVJVDNQUmZPakY4eGtkTWJpMHp2akhZaW42N0JoVkEK"
    }
  }
}
